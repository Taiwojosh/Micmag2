# Admin Portal Authentication
# REQUIRED — the server will refuse to start if this is not set.
# To support multiple admins, separate passcodes with a comma (no spaces around commas):
#   ADMIN_PASSCODE=alice_secret,bob_secret,charlie_secret
ADMIN_PASSCODE=your_secure_passcode_here

# Google Apps Script Web App URL (paste after deploying Code.gs)
# See: google-apps-script/Code.gs for full setup instructions
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# NOTE: leads.json is intentionally excluded from git via .gitignore.
# Customer PII (names, emails, phone numbers) must never be committed.
# The primary lead record is in the connected Google Sheet.
